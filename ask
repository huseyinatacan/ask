#!/bin/bash


answer=$(curl $ASK_API_URL -s \
	-H "Content-Type: application/json" \
	-H "Authorization: Bearer $ASK_API_KEY" \
	-d '{
		"model": "'"$ASK_API_MODEL"'",
		"input": [
		{
			"role": "system",
			"content": "You are a CLI tool. Output plain text only. No yapping. Keep the output concise."
		},
		{
			"role": "user",
			"content": "'"$*"'"
		}
	]
}')

echo $answer | egrep -o '"text": "[^"]+" } ]' |  sed -e 's/"text": "//' -e  's/" } ]//' -e 's/\\n/\n/g'
