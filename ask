#!/bin/bash

if [ -t 0 ]
then
	
	prompt="$*"
else
	input=$(cat)
	prompt="$* $input"
fi

if [ -z "$prompt" ]
then
	echo "You need to provide input"
	exit 1
fi
escaped_prompt=$(echo "$prompt" | jq -Rs .)

answer=$(curl "$ASK_API_URL" -s \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $ASK_API_KEY" \
  -d "{
    \"model\": \"$ASK_API_MODEL\",
    \"input\": [
      {
        \"role\": \"system\",
        \"content\": \"You are a CLI tool. Output plain text only. No yapping. Keep the output concise.\"
      },
      {
        \"role\": \"user\",
        \"content\": $escaped_prompt
      }
    ]
  }"
)

echo "$answer" | jq -r '(.output[]?.content[]?.text) // .error.message'
